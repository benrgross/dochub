# Copy this file to .env.local and fill in real values.
# Better: run `pnpm dlx vercel link && pnpm dlx vercel env pull .env.local`
# after linking and Vercel will populate everything for you.

# -----------------------------------------------------------------------------
# Supabase (REQUIRED) — used by lib/supabase/service.ts (cached reads) and
# lib/supabase/server.ts (Server Actions, future RLS). The anon key is fine
# in v1 because RLS is off; v2 will switch to a service-role key here.
# Grab these from your Supabase project: Settings → API.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# -----------------------------------------------------------------------------
# AI Gateway (REQUIRED for /api/ai-edit)
#
# Preferred: enable AI Gateway in Vercel (Project → Settings → AI Gateway),
# then `pnpm dlx vercel env pull .env.local` and you'll get
# VERCEL_OIDC_TOKEN automatically (short-lived JWT, ~24h, refreshes on pull).
#
# Alternative (CI / non-Vercel envs): set a static AI_GATEWAY_API_KEY.
# Do NOT set OPENAI_API_KEY / ANTHROPIC_API_KEY — that bypasses the gateway.
# -----------------------------------------------------------------------------
# VERCEL_OIDC_TOKEN=                       # populated by `vercel env pull`
# AI_GATEWAY_API_KEY=                      # static fallback (optional)

# -----------------------------------------------------------------------------
# Edge Config (OPTIONAL) — kill switch + model override for AI Branch.
# If unset, lib/flags.ts falls back to AI_BRANCH_ENABLED / AI_MODEL_OVERRIDE
# below. Skip this entirely for local dev; add it for the production demo
# so you can flip flags without redeploying.
# -----------------------------------------------------------------------------
# EDGE_CONFIG=https://edge-config.vercel.com/ecfg_xxx?token=yyy

# Local-dev fallback flags (used only when EDGE_CONFIG is not set)
# AI_BRANCH_ENABLED=true                   # set to "false" to disable AI Branch
# AI_MODEL_OVERRIDE=anthropic/claude-sonnet-4.6
