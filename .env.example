# Copy this file to .env.local and fill in real values.
# Or run `pnpm dlx vercel link && pnpm dlx vercel env pull .env.local` and
# Vercel will populate everything from the linked project.

# -----------------------------------------------------------------------------
# Supabase (required) — used by lib/supabase/service.ts (cached reads) and
# lib/supabase/server.ts (Server Actions). Grab from Project → Settings → API.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# -----------------------------------------------------------------------------
# AI Gateway (required for /api/ai-edit)
#
# Preferred: enable AI Gateway in Vercel (Project → Settings → AI Gateway),
# then `pnpm dlx vercel env pull .env.local` populates VERCEL_OIDC_TOKEN
# automatically (short-lived JWT, refreshes on pull).
#
# Alternative (CI / non-Vercel envs): set a static AI_GATEWAY_API_KEY.
# Do NOT set OPENAI_API_KEY / ANTHROPIC_API_KEY — that bypasses the gateway.
# -----------------------------------------------------------------------------
# VERCEL_OIDC_TOKEN=                       # populated by `vercel env pull`
# AI_GATEWAY_API_KEY=                      # static fallback (optional)

# -----------------------------------------------------------------------------
# Edge Config (optional) — kill switch + model override for AI Branch.
# If unset, lib/flags.ts falls back to the env vars below.
# -----------------------------------------------------------------------------
# EDGE_CONFIG=https://edge-config.vercel.com/ecfg_xxx?token=yyy

# Fallback flags (used only when EDGE_CONFIG is not set)
# AI_BRANCH_ENABLED=true                   # set to "false" to disable AI Branch
# AI_MODEL_OVERRIDE=anthropic/claude-sonnet-4.6
